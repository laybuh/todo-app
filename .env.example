# PostgreSQL (Render in prod, localhost in dev)
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432
# TLS: paste your provider's CA cert (e.g. Render's) to verify the DB server. Recommended in prod.
DB_CA_CERT=
# Set to true once DB_CA_CERT is configured to refuse unverified connections in production.
DB_STRICT_SSL=

# Auth / crypto secrets — generate strong random values, never commit real ones
SECRETEST_KEY=                # JWT signing secret
ENCRYPTION_KEY=               # exactly 32 bytes (AES-256-GCM)

# Email (Resend)
RESEND_API_KEY=

# URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
# Extra allowed CORS origins, comma-separated (e.g. Vercel preview URLs)
ALLOWED_ORIGINS=

# Admin (owner-only) — separate from user auth
ADMIN_SECRET=           # long random string; gates /admin
ADMIN_EMAIL=            # where anomaly alerts are sent

# Server
PORT=5000
